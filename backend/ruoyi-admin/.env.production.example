# Backend env example (production)
# Used by Spring placeholders in:
# - ruoyi-admin/src/main/resources/application.yml
# - ruoyi-admin/src/main/resources/application-druid.yml
#
# Notes:
# - This file is NOT auto-loaded by Spring Boot. Source it in your service manager
#   (systemd / docker / shell) before starting the jar.

# --- App / Server ---
SERVER_PORT=9090
LOG_LEVEL=INFO
UPLOAD_PATH=/opt/huazhi-backend/uploads/

# --- JWT (must be set; >= 32 chars) ---
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRATION=86400

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Keep empty if Redis has no password, otherwise Spring will AUTH and may fail.
REDIS_PASSWORD=

# --- MySQL Master (required) ---
DB_MASTER_HOST=127.0.0.1
DB_MASTER_PORT=3306
DB_MASTER_NAME=hz-vue
DB_MASTER_USERNAME=app_user
DB_MASTER_PASSWORD=replace-with-db-password

# --- MySQL DB2 (hotel_training) ---
# Dual-db deployments should keep this enabled. Set to false only for single-db deployments.
DB_SLAVE_ENABLED=true
DB_SLAVE_HOST=127.0.0.1
DB_SLAVE_PORT=3306
DB_SLAVE_NAME=hotel_training
DB_SLAVE_USERNAME=app_user
DB_SLAVE_PASSWORD=replace-with-db-password

# --- AI Provider (backend only) ---
DASHSCOPE_API_KEY=sk-replace-with-real-key

# --- Druid console (recommended to set in production) ---
DRUID_LOGIN_USERNAME=ruoyi
DRUID_LOGIN_PASSWORD=replace-with-strong-password
