# Backend env example (local dev)
# Source this file in your terminal before starting the backend.

SERVER_PORT=9090
LOG_LEVEL=DEBUG
UPLOAD_PATH=E:\\training_agent\\uploads\\

# JWT_SECRET must be >= 32 chars (see TokenService.validateSecret fail-fast)
JWT_SECRET=dev-only-secret-change-me-32chars!
JWT_EXPIRATION=86400

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

DB_MASTER_HOST=127.0.0.1
DB_MASTER_PORT=3306
DB_MASTER_NAME=hz-vue
DB_MASTER_USERNAME=root
DB_MASTER_PASSWORD=

# DB2 (hotel_training). Dual-db deployments should keep this enabled.
DB_SLAVE_ENABLED=true
DB_SLAVE_HOST=127.0.0.1
DB_SLAVE_PORT=3306
DB_SLAVE_NAME=hotel_training
DB_SLAVE_USERNAME=root
DB_SLAVE_PASSWORD=

# Optional (leave empty if not testing AI locally)
DASHSCOPE_API_KEY=

DRUID_LOGIN_USERNAME=ruoyi
DRUID_LOGIN_PASSWORD=dev-only-change-me
