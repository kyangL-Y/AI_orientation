# Core endpoint
PERM3_BASE_URL=http://127.0.0.1:9090
PERM3_API_PREFIX=

# Admin auth (choose token mode OR username/password mode)
PERM3_ADMIN_TOKEN=
PERM3_ADMIN_USERNAME=
PERM3_ADMIN_PASSWORD=
PERM3_ADMIN_TENANT_ID=
PERM3_ADMIN_LOGIN_PATH=/admin/login

# Target user auth
PERM3_USER_TOKEN=
PERM3_USER_USERNAME=
PERM3_USER_PASSWORD=
PERM3_USER_TENANT_ID=
PERM3_USER_LOGIN_PATH=/login

# Role selector (prefer role id)
PERM3_ROLE_ID=
PERM3_ROLE_KEY=
PERM3_ROLE_NAME=

# Permission expectation
PERM3_EXPECTED_PERM=train:exam:edit

# Protected endpoint probe
# Safe default read probe:
PERM3_PROBE_METHOD=GET
PERM3_PROBE_PATH=/train/exam/admin/list?pageNum=1&pageSize=1
PERM3_PROBE_BODY=

# Role grant/revoke APIs
PERM3_GRANT_PATH=/system/role/authUser/selectAll
PERM3_REVOKE_PATH=/system/role/authUser/cancelAll

# Common APIs
PERM3_CAPTCHA_PATH=/captchaImage
PERM3_GETINFO_PATH=/getInfo

# Report outputs
PERM3_REPORT_JSON=E:/training_agent/training-agent-master/docs/perm3_dynamic_report.json
PERM3_REPORT_MD=E:/training_agent/training-agent-master/docs/perm3_dynamic_report.md
