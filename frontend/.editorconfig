root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,vue,ts,json,md,html,css,scss,less}]
charset = utf-8

[*.{env,properties}]
charset = utf-8

[*.py]
charset = utf-8

[*.{yml,yaml}]
charset = utf-8

[*.md]
trim_trailing_whitespace = false
